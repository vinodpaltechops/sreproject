{
  "title": "Trade Service — SRE Lab",
  "uid": "trade-service-sre",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Trades",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "trades_total{job=\"trade-service\"}",
        "legendFormat": "Total"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "Successful Trades",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "trades_success_total{job=\"trade-service\"}",
        "legendFormat": "Success"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 3,
      "title": "Failed Trades",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "trades_failed_total{job=\"trade-service\"}",
        "legendFormat": "Failed"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 4,
      "title": "Pending Trades",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "trades_pending_count{job=\"trade-service\"}",
        "legendFormat": "Pending"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } }
    },
    {
      "id": 5,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 * trades_failed_total{job=\"trade-service\"} / clamp_min(trades_total{job=\"trade-service\"}, 1)",
        "legendFormat": "Error %"
      }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 6,
      "title": "Trade Throughput (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(trades_total{job=\"trade-service\"}[1m])",
          "legendFormat": "Total req/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(trades_success_total{job=\"trade-service\"}[1m])",
          "legendFormat": "Success req/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(trades_failed_total{job=\"trade-service\"}[1m])",
          "legendFormat": "Failed req/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 7,
      "title": "Processing Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "trade_processing_duration_seconds{job=\"trade-service\", quantile=\"0.5\"}",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "trade_processing_duration_seconds{job=\"trade-service\", quantile=\"0.95\"}",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "trade_processing_duration_seconds{job=\"trade-service\", quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 8,
      "title": "Notional Value Processed (USD)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(trade_notional_value_USD_sum{job=\"trade-service\"}[1m])",
        "legendFormat": "USD/s"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "lineWidth": 2, "fillOpacity": 15 } } }
    },
    {
      "id": 9,
      "title": "Circuit Breaker & Rate Limiter — Rejected Trades",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(trades_rejected_total{job=\"trade-service\"}[1m])",
        "legendFormat": "Rejected/s"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "orange", "mode": "fixed" }, "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 10,
      "title": "Trade Service Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 8 },
      "targets": [{
        "datasource": "Loki",
        "expr": "{job=\"trade-service\"}",
        "legendFormat": ""
      }],
      "options": { "dedupStrategy": "none", "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true }
    }
  ]
}
